class ExtractRasterValuesAtPoints(object):
    OBJ_ID = "OID"
    WORKSPACE = "WORKSPACE"
    OUT_WORKSPACE = "OUTWORKSPACE"
    RASTER = "RASTER"
    EXEC_STR = "EXECSTR"
    NEWCOL = "NEWCOL"
    SECTION_NAME = "raster"
    POSTFIX = "POSTFIX"
    WILDCARD = "WILDCARD"
    REMOVE_FIELDS = "REMOVE"
    REMOVE_STRINGS = "RMSTRINGS"
    param_positions = {}

    def __init__(self):
        """Define the tool (tool name is the name of the class)."""
        self.label = "Add Raster Value to Points"
        self.description = "Using a raster dataset and a point feature class, add a field to the points class and place the corresponding raster data into new field.  Optionally create another field based using a python exec string (for UKC by default)"
        self.canRunInBackground = False

    def getParameterInfo(self):
        """Define parameter definitions"""
        config = ConfigParser.RawConfigParser({self.RASTER: enc_depth30m, self.POSTFIX: "AIS*", self.POSTFIX: "_Depths",
                                               self.NEWCOL: "ENCDepth", self.EXEC_STR: "pts['UKC'] = pts['ENCDepth'] - pts['DRAFT_MAX']",
                                               self.OBJ_ID: "OBJECTID_1", self.WORKSPACE: AIS_local__gdb,
                                               self.REMOVE_FIELDS: "OID,Shape,IMO,OBJECTID,OBJECTID_1,OBJECTID_2",
                                               self.REMOVE_STRINGS: 0
                                               })
