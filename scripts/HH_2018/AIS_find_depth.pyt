ini_filename = os.path.dirname(__file__) + "\\PydroGIS.ini"


def SetupConfigParser(add_section, config=None):
    '''Loads the ini file and makes sure "add_section" exists.
    Creates a RawConfigParser if nothing is passed in, or accepts a prebuilt config parser with defaults'''
    if not config:
        config = ConfigParser.RawConfigParser()
    try:
        config.readfp(open(ini_filename, "r"))
    except:
        pass
    try:
        config.add_section(add_section)
    except:
        pass
    return config


