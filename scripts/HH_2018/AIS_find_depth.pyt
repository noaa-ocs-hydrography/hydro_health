            parameterType="Required",
            direction="Input")
        try:
            raster.value = config.get(self.SECTION_NAME, raster.name)
        except:
            pass

        workspace = arcpy.Parameter(
            displayName="Workspace (GDB, file folder etc)",
            name=self.WORKSPACE,
            datatype="DEWorkspace",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Required",
            direction="Input")
        try:
            workspace.value = config.get(self.SECTION_NAME, self.WORKSPACE)
        except:
            pass

        wildcard = arcpy.Parameter(
            displayName="Wildcard (blank gets all feature classes)",
            name=self.WILDCARD,
            datatype="GPString",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Optional",
            direction="Input")
        try:
            wildcard.value = config.get(self.SECTION_NAME, self.WILDCARD)
        except:
            pass

        out_workspace = arcpy.Parameter(
            displayName="Output Workspace (GDB, file folder etc)",
            name=self.OUT_WORKSPACE,
            datatype="DEWorkspace",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Required",
            direction="Input")
        try:
            out_workspace.value = config.get(self.SECTION_NAME, self.OUT_WORKSPACE)
        except:
            pass

        Postfix = arcpy.Parameter(
            displayName="Postfix to append to layer names",
            name=self.POSTFIX,
            datatype="GPString",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Required",
            direction="Input")
        try:
            Postfix.value = config.get(self.SECTION_NAME, self.POSTFIX)
        except:
            pass

        ColumnName = arcpy.Parameter(
            displayName="Column name to add raster data into",
            name=self.NEWCOL,
            datatype="GPString",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Required",
            direction="Input")
        try:
            ColumnName.value = config.get(self.SECTION_NAME, ColumnName.name)
        except:
            pass

        exec_str = arcpy.Parameter(
            displayName="Code to execute",
            name=self.EXEC_STR,
            datatype="GPString",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Optional",
            direction="Input")
        try:
            exec_str.value = config.get(self.SECTION_NAME, exec_str.name)
        except:
            pass

        removefields = arcpy.Parameter(
            displayName="Remove Columns from Dataset",
            name=self.REMOVE_FIELDS,
            datatype="Field",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Optional",
            direction="Input")
        try:
            removefields.value = config.get(self.SECTION_NAME, removefields.name)
        except:
            pass
        removestrings = arcpy.Parameter(
            displayName="Remove strings larger than (useful for memory usage):",
            name=self.REMOVE_STRINGS,
            datatype="GPLong",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Optional",
            direction="Input")
        try:
            removestrings.value = config.get(self.SECTION_NAME, removestrings.name)
        except:
            pass

        objectid = arcpy.Parameter(
            displayName="Object ID column",
            name=self.OBJ_ID,
            datatype="Field",  # "GPFeatureRecordSetLayer", #"DEFeatureDataset", #"GPLayer", #"DEFeatureClass", #"GPFeatureLayer",
            parameterType="Optional",
            direction="Input")
        try:
            objectid.value = config.get(self.SECTION_NAME, objectid.name)
        except:
            pass

        parameters = [raster, workspace, wildcard, out_workspace, Postfix, ColumnName, exec_str, removefields, removestrings, objectid]
        for i, param in enumerate(parameters):
